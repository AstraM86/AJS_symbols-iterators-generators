{
  "extends": "airbnb-base",
  "env": {
    "browser": true,
    "jest": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-new": "off",
    "import/prefer-default-export": "off",
    "no-console": "off",
    "no-undef": "off"
  }
}
